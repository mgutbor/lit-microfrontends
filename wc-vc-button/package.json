{
    "name": "wc-vc-button",
    "version": "1.0.0",
    "description": "Componente botón genérico con patrón MVVM",
    "main": "index.ts",
    "module": "index.ts",
    "types": "index.ts",
    "type": "module",
    "author": "STIC",
    "license": "ISC",
    "scripts": {
        "start": "vite",
        "dev": "concurrently -p\"[{name}]\" -n Build,Preview -c \"bgBlue.bold,bgCyan.bold\"  \"npm run build-watch\" \"npm run preview\"",
        "clean": "npx rimraf dist node_modules package-lock.json",
        "build": "tsc && vite build",
        "build-watch": "vite build --watch",
        "preview": "vite preview"
    },
    "dependencies": {
        "lit": "2.8.0",
        "@material/web": "^2.2.0"
    },
    "devDependencies": {
        "@module-federation/vite": "1.14.4",
        "@types/node": "25.6.0",
        "concurrently": "9.2.1",
        "typescript": "6.0.3",
        "vite": "8.0.8"
    },
    "files": [
        "dist/**",
        "LICENSE",
        "package.json",
        "README.md",
        "CHANGELOG.md"
    ]
}
